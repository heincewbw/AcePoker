PORT=5000
CLIENT_URL=http://localhost:5173

# Supabase (get these from https://app.supabase.com → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Blockchain config (BSC Mainnet for USDT)
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
USDT_CONTRACT_ADDRESS_BSC=0x55d398326f99059fF775485246999027B3197955
USDT_CONTRACT_ADDRESS_BSC_TESTNET=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd

# Deposit wallet address (your platform's wallet)
PLATFORM_WALLET_ADDRESS=0xYourPlatformWalletAddressHere
PLATFORM_WALLET_PRIVATE_KEY=your_platform_wallet_private_key_here

# Use testnet for development
USE_TESTNET=true
